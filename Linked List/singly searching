#include <iostream>
using namespace std;

struct node {
    int data;
    node* next;
    node(int value) {
        data = value;
        next = NULL;
    }
};

node* head = NULL;
void insertAtEnd(int value) {
    node* newNode = new node(value);
    if (head == NULL) {
        head = newNode;
        return;
    }
    node* temp = head;
    while (temp->next != NULL) {
        temp = temp->next;
    }
    temp->next = newNode;
}
bool searchValue(int value) {
    node* temp = head;
    while (temp != NULL) {
        if (temp->data == value) return true;
        temp = temp->next;
    }
    return false;
}
int searchPosition(int value) {
    node* temp = head;
    int index = 0;
    while (temp != NULL) {
        if (temp->data == value) return index;
        temp = temp->next;
        index++;
    }
    return -1; 
}
int countOccurrences(int value) {
    node* temp = head;
    int count = 0;
    while (temp != NULL) {
        if (temp->data == value) count++;
        temp = temp->next;
    }
    return count;
}
int findMax() {
    if (head == NULL) {
        cout << "List is empty!" << endl;
        return -1;
    }
    int maxVal = head->data;
    node* temp = head->next;
    while (temp != NULL) {
        if (temp->data > maxVal) maxVal = temp->data;
        temp = temp->next;
    }
    return maxVal;
}
int findMin() {
    if (head == NULL) {
        cout << "List is empty!" << endl;
        return -1;
    }
    int minVal = head->data;
    node* temp = head->next;
    while (temp != NULL) {
        if (temp->data < minVal) minVal = temp->data;
        temp = temp->next;
    }
    return minVal;
}

void display() {
    node* temp = head;
    while (temp != NULL) {
        cout << temp->data << "->";
        temp = temp->next;
    }
    cout << "NULL" << endl;
}

int main() {
    
    insertAtEnd(10);
    insertAtEnd(20);
    insertAtEnd(30);
    insertAtEnd(20);
    insertAtEnd(40);

    cout << "Initial List: ";
    display();

  
    cout << "Search value 20: " 
         << (searchValue(20) ? "Found" : "Not Found") << endl;

    cout << "Position of 30: " << searchPosition(30) << endl;

    cout << "Occurrences of 20: " << countOccurrences(20) << endl;

    cout << "Maximum value: " << findMax() << endl;

    cout << "Minimum value: " << findMin() << endl;

    return 0;
}
