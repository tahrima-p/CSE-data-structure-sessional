#include <iostream>
#include <vector>
#include <climits>
using namespace std;

#define INF INT_MAX

// Function to find the vertex with minimum key value not yet included in MST
int minKey(vector<int>& key, vector<bool>& inMST, int V) {
    int min = INF, minIndex;
    for (int v = 0; v < V; v++) {
        if (!inMST[v] && key[v] < min) {
            min = key[v];
            minIndex = v;
        }
    }
    return minIndex;
}

// Prim’s Algorithm
void primMST(vector<vector<int>>& graph, int V) {
    vector<int> parent(V, -1);   // Stores MST edges
    vector<int> key(V, INF);     // Minimum edge weight to connect vertex
    vector<bool> inMST(V, false); // Track vertices included in MST

    key[0] = 0; // Start from vertex 0

    for (int count = 0; count < V - 1; count++) {
        int u = minKey(key, inMST, V);
        inMST[u] = true;

        for (int v = 0; v < V; v++) {
            if (graph[u][v] && !inMST[v] && graph[u][v] < key[v]) {
                parent[v] = u;
                key[v] = graph[u][v];
            }
        }
    }

    cout << "Edges in MST (Prim's Algorithm):\n";
    for (int i = 1; i < V; i++) {
        cout << char('A' + parent[i]) << " - " << char('A' + i)
             << "  weight: " << graph[i][parent[i]] << endl;
    }
}

int main() {
    int V;
    cout << "Enter number of vertices: ";
    cin >> V;

    vector<vector<int>> graph(V, vector<int>(V, 0));

    cout << "Enter adjacency matrix (use 0 if no edge):\n";
    for (int i = 0; i < V; i++) {
        for (int j = 0; j < V; j++) {
            cin >> graph[i][j];
        }
    }

    primMST(graph, V);

    return 0;
}
