#include <iostream>
using namespace std;

struct Vertex {
    char data;        // vertex label
    Vertex* next;     // pointer to next adjacent vertex
};

int main() {
    int m; // number of vertices
    cout << "Enter number of vertices: ";
    cin >> m;

    // Table of adjacency lists
    Vertex* table[m];

    // Initialize table
    for (int i = 0; i < m; i++) {
        table[i] = NULL;
    }

    // Input graph edges
    int edges;
    cout << "Enter number of edges: ";
    cin >> edges;

    for (int i = 0; i < edges; i++) {
        char u, v;
        cout << "Enter edge (u v): ";
        cin >> u >> v;

        // Create node for v
        Vertex* nptr = new Vertex;
        nptr->data = v;
        nptr->next = NULL;

        int idx = u - 'A'; // assuming vertices are labeled A, B, C...
        if (table[idx] == NULL) {
            table[idx] = nptr;
        } else {
            Vertex* tptr = table[idx];
            while (tptr->next != NULL) {
                tptr = tptr->next;
            }
            tptr->next = nptr;
        }
    }

    // Output adjacency list
    cout << "\nAdjacency List:\n";
    for (int i = 0; i < m; i++) {
        cout << char('A' + i) << " -> ";
        Vertex* tptr = table[i];
        while (tptr != NULL) {
            cout << tptr->data << " ";
            tptr = tptr->next;
        }
        cout << endl;
    }

    return 0;
}
