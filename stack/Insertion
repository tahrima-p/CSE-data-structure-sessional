#include<iostream>
using namespace std;
class stack{
    private:
    int *arr;
    int top;
    int size;
    public:
    stack(int capacity)
    {
        size=capacity;
        top=-1;
        arr=new int[size];

    }
    void push(int val)
    {
        if(top>=size-1)
        {
            cout<<"stack overflow\n";
            return;
        }
        top++;
        arr[top]=val;
    }
    void pop()
    {
        if(top==-1){
            cout<<"stack is empty ";
return;
        }
        top--;
    }
    int peek(){
        if(top==-1){
            cout<<"stack is empty !"<<endl;
            return -1;
        }
        return arr[top];

    }
    bool isEmpty(){
        if(top==-1){
            return true;

        }
        return false;
    }
    void display(){
        if(top==-1){
            cout<<"the stack is empty";
            return;
        }
        cout<<"stack elements (top to bottom):";
        for(int i=top;i>=0;i--){
            cout<<arr[i]<<" ";
        }
        cout<<endl;
    }
    
};
int main()
{
    stack s(5);
    s.push(10);
    s.push(20);
    s.push(30);
    s.push(40);
    s.display();
    cout<<"top element:"<<s.peek()<<endl;
    s.pop();
    cout<<"stack empty situation :"<<s.isEmpty();
}
