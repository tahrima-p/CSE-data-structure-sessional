#include<iostream>
using namespace std;
int main()
{
    int arr[]={1,3,4,5,9,0,6};
    int size=sizeof(arr)/sizeof(arr[0]);
    cout<<"printing the original array:"<<endl;
    for(int i=0;i<size;i++)
    {
        cout<<arr[i]<<" ";

    }
    for(int pass=1;pass<size;pass++)
    {
        for(int i=0;i<size-pass;i++)
        {
            if(arr[i]>arr[i+1])
            {
                swap(arr[i],arr[i+1]);
            }
        }
    }
    cout<<"printing the array after sorting:"<<endl;
    for(int i =0;i<size;i++)
    {
        cout<<arr[i]<<" ";
    }
    cout<<endl;
    return 0;
}
