#include <iostream>
using namespace std;

int main() {
    int arr[7] = {1, 2, 3, 4, 5};
    int n = 5; 
    int x = 6; 
    for (int i = n; i > 0; i--) {
        arr[i] = arr[i-1];
    }
    arr[0] = x;
    n++;

    cout << "After insertion: ";
    for (int i = 0; i < n; i++) cout << arr[i] << " ";
}
