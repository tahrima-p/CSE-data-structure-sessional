#include <iostream>
using namespace std;

int main() {
    int arr[10] = {100, 200, 300, 400, 500};
    int n = 5;  
    int x = 350;  
    int pos = 0;
    while (pos < n && arr[pos] < x) {
        pos++;
    }
    for (int i = n; i > pos; i--) {
        arr[i] = arr[i-1];
    }
    arr[pos] = x;
    n++;

    cout << "Array after insertion: ";
    for (int i = 0; i < n; i++) cout << arr[i] << " ";
}
