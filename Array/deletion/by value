#include <iostream>
using namespace std;

int main() {
    int arr[10] = {10, 20, 30, 40, 50};
    int n = 5;
    int value = 30;

    cout << "Original array: ";
    for(int i = 0; i < n; i++) cout << arr[i] << " ";
    cout << endl;
    int pos = -1;
    for(int i = 0; i < n; i++) {
        if(arr[i] == value) {
            pos = i;
            break;
        }
    }

    if(pos != -1) {
        for(int i = pos; i < n - 1; i++) {
            arr[i] = arr[i + 1];
        }
        n--;
    }

    cout << "After deleting value " << value << ": ";
    for(int i = 0; i < n; i++) cout << arr[i] << " ";
    cout << endl;

    return 0;
}
