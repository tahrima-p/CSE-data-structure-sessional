#include <iostream>
#include <cmath>
using namespace std;

// Linear Search
int linearSearch(int arr[], int n, int key) {
    for (int i = 0; i < n; i++) {
        if (arr[i] == key) return i;
    }
    return -1;
}

// Binary Search (array must be sorted)
int binarySearch(int arr[], int n, int key) {
    int low = 0, high = n - 1;
    while (low <= high) {
        int mid = (low + high) / 2;
        if (arr[mid] == key) return mid;
        else if (arr[mid] < key) low = mid + 1;
        else high = mid - 1;
    }
    return -1;
}

int main() {
    int arr[] = {11, 22, 25, 34, 64, 90};
    int n = sizeof(arr) / sizeof(arr[0]);
    int key;

    cout << "Enter element to search: ";
    cin >> key;

    cout << "\nLinear Search: ";
    int res1 = linearSearch(arr, n, key);
    if (res1 != -1) cout << "Found at index " << res1;
    else cout << "Not found";

    cout << "\nBinary Search: ";
    int res2 = binarySearch(arr, n, key);
    if (res2 != -1) cout << "Found at index " << res2;
    else cout << "Not found";

    return 0;
}
